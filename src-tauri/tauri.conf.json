{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shopify Product Collection Upload",
  "version": "1.0.1",
  "identifier": "de.hausone.productcollectionupload",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shopify Product Collection Upload",
        "width": 1350,
        "height": 900,
        "minWidth": 950,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Business",
    "copyright": "Copyright 2026 Hausone GmbH",
    "homepage": "https://hausone.de",
    "shortDescription": "Multi-store Shopify product and collection manager",
    "longDescription": "A local multi-store desktop application for Shopify product import, product export, hybrid collection import and export, history, templates, backup, diagnostics, and per-store settings.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
